# ─── Скопируйте этот файл в .env.local и заполните своими ключами ───
# cp .env.example .env.local

# ─── Apify (обязательно для 2gis-lead-gen) ─────────────────────────
# Получить ключ: https://console.apify.com/account/integrations
# Бесплатный план даёт $5/мес кредитов — этого хватает на ~150-180 лидов
APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Serper.dev (обязательно для 2gis-lead-gen — поиск владельца) ──
# Получить ключ: https://serper.dev/
# 2500 бесплатных запросов в месяц
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── ОПЦИОНАЛЬНО: 2GIS Catalog API (бесплатная альтернатива Apify) ──
# Если получишь ключ от 2GIS sales (dev@2gis.ru) с правами на
# contact_groups — скилл автоматически переключится на этот API
# и перестанет тратить Apify credits.
#TWOGIS_API_KEY=

# ─── Google Sheets ─────────────────────────────────────────────────
# Путь к service-account JSON (обычно ./service_account.json в корне)
# Сам файл получить в Google Cloud Console → IAM → Service Accounts
# Не забыть поделиться нужной Google Sheet с email сервис-аккаунта
GOOGLE_SERVICE_ACCOUNT_PATH=./service_account.json

# ─── ОПЦИОНАЛЬНО: Telegram прогресс-уведомления ────────────────────
# Бот создаётся через @BotFather, chat_id — твой Telegram user id
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_REPORT_CHAT_ID=
